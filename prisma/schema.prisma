generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id
  email               String               @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  firstName           String?
  imageUrl            String?
  lastName            String?
  accessRequests      AccessRequest[]
  accessRequestEvents AccessRequestEvent[]
  projects            Project[]
  memberships         ProjectMember[]
  notifications       Notification[]
  sentInvitations     ProjectInvitation[]  @relation("InvitedBy")
  receivedInvitations ProjectInvitation[]  @relation("UserInvitation")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String?
  projectId String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
}

model Project {
  id             String              @id @default(cuid())
  name           String
  description    String?
  thumbnail      String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  ownerId        String
  visibility     ProjectVisibility   @default(public)
  accessRequests AccessRequest[]
  invitations    ProjectInvitation[]
  pages          Page[]
  User           User                @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members        ProjectMember[]

  @@index([ownerId])
}

model Page {
  id        String   @id @default(cuid())
  name      String   @default("Page 1")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projectId String
  nodes     Node[]
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Node {
  id          String      @id @default(cuid())
  parentId    String?
  pageId      String
  type        NodeType
  x           Float
  y           Float
  width       Float
  height      Float
  radius      Float       @default(0)
  text        String?
  fill        String      @default("#ffffff")
  stroke      String      @default("#000000")
  strokeWidth Float       @default(1)
  strokeStyle StrokeStyle @default(solid)
  rotation    Float       @default(0)
  opacity     Float       @default(1)
  fontSize    Float       @default(14)
  fontFamily  String      @default("Arial")
  zIndex      Int         @default(0)
  imageUrl    String?
  points      Float[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  page        Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  Node        Node?       @relation("NodeToNode", fields: [parentId], references: [id], onDelete: Cascade)
  other_Node  Node[]      @relation("NodeToNode")

  @@index([pageId])
  @@index([parentId])
}

model ProjectMember {
  id          String     @id @default(cuid())
  projectId   String
  userId      String
  role        MemberRole @default(editor)
  joinedAt    DateTime   @default(now())
  favoritedAt DateTime?
  archivedAt  DateTime?
  lastOpenedAt DateTime?
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
  @@index([archivedAt])
  @@index([favoritedAt])
}

model ProjectInvitation {
  id          String           @id @default(cuid())
  projectId   String
  invitedById String
  email       String?
  userId      String?
  token       String           @unique @default(cuid())
  status      InvitationStatus @default(pending)
  expiresAt   DateTime
  message     String?
  role        MemberRole       @default(editor)
  oneTime     Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invitedBy   User             @relation("InvitedBy", fields: [invitedById], references: [id])
  user        User?            @relation("UserInvitation", fields: [userId], references: [id])

  @@index([projectId])
  @@index([userId])
  @@index([email])
  @@index([status])
  @@index([token])
}

model AccessRequest {
  id            String        @id @default(cuid())
  projectId     String
  userId        String
  status        RequestStatus @default(pending)
  message       String?
  requestedRole String        @default("editor")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  events AccessRequestEvent[]

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
  @@index([status])
}

model AccessRequestEvent {
  id              String         @id @default(cuid())
  accessRequestId String
  fromStatus      RequestStatus?
  toStatus        RequestStatus
  changedById     String?
  reason          String?
  createdAt       DateTime       @default(now())
  accessRequest   AccessRequest  @relation(fields: [accessRequestId], references: [id], onDelete: Cascade)
  changedBy       User?          @relation(fields: [changedById], references: [id])

  @@index([accessRequestId])
  @@index([changedById])
}

enum NodeType {
  rect
  circle
  text
  frame
  star
  diamond
  image
}

enum StrokeStyle {
  solid
  dashed
}

enum ProjectVisibility {
  public
  private
}

enum MemberRole {
  owner
  editor
  viewer
}

enum InvitationStatus {
  pending
  accepted
  cancelled
  expired
}

enum RequestStatus {
  pending
  approved
  denied
  cancelled
}
